
<!doctype html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
<title>Solicitar Mantenimiento</title>
<style>
  * { box-sizing: border-box; }
  body {
    margin: 0; min-height: 100vh; background: #F5F3EF; color: #22261F;
    font-family: Inter, system-ui, sans-serif;
    display: flex; align-items: center; justify-content: center; padding: 20px;
  }
  .card {
    background: #fff; border: 1px solid #E3DFD8; border-radius: 12px;
    padding: 28px; width: 100%; max-width: 420px;
  }
  h1 {
    font-family: Oswald, Arial Narrow, sans-serif; text-transform: uppercase;
    font-size: 20px; margin: 0 0 4px; letter-spacing: 0.5px;
  }
  h1 span { color: #2F6B2F; }
  .sub { font-size: 13px; color: #6E766E; margin-bottom: 20px; }
  label { display: block; font-size: 12px; font-weight: 700; color: #6E766E; margin-bottom: 5px; margin-top: 14px; }
  select, input, textarea {
    width: 100%; padding: 10px; border: 1px solid #E3DFD8; border-radius: 6px;
    font-size: 14px; font-family: inherit; background: #fff; color: #22261F;
  }
  textarea { min-height: 90px; resize: vertical; }
  button {
    width: 100%; margin-top: 20px; padding: 12px; border: none; border-radius: 7px;
    background: #2F6B2F; color: #fff; font-weight: 700; font-size: 14px; cursor: pointer;
  }
  button:disabled { opacity: 0.6; }
  .msg { margin-top: 14px; padding: 10px; border-radius: 7px; font-size: 13px; display: none; }
  .msg.ok { background: rgba(47,107,47,0.12); color: #2F6B2F; display: block; }
  .msg.error { background: rgba(122,15,19,0.10); color: #7A0F13; display: block; }
  .loading { text-align: center; color: #6E766E; font-size: 13px; padding: 20px 0; }
</style>
</head>
<body>
  <div class="card">
    <h1>Solicitar <span>Mantenimiento</span></h1>
    <div class="sub">Completá los datos y avisamos al taller.</div>

    <div id="loading" class="loading">Cargando vehículos...</div>

    <form id="form" style="display:none">
      <label>Vehículo</label>
      <select id="placa" required></select>

      <label>Tu nombre (chofer)</label>
      <input id="motorista" type="text" required />

      <label>¿Qué problema tiene?</label>
      <textarea id="descripcion" required placeholder="Ej: Frenos hacen ruido, pierde aceite, luces no funcionan..."></textarea>

      <label>Urgencia</label>
      <select id="urgencia">
        <option value="Normal">Normal</option>
        <option value="Urgente">Urgente</option>
      </select>

      <button type="submit" id="btn">Enviar solicitud</button>
    </form>

    <div id="msg" class="msg"></div>
  </div>

<script>
  // Mismos datos de Supabase que usa el resto de la app.
  const SUPABASE_URL = "https://ixisizlclxviwcgmnoyx.supabase.co";
  const SUPABASE_ANON_KEY = "sb_publishable_DvH5wNdko1aTt6hAjtFU7A_F3yJPfSz";

  const headers = {
    apikey: SUPABASE_ANON_KEY,
    Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
    "Content-Type": "application/json",
  };

  async function getValor(key, def) {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/app_storage?key=eq.${key}&shared=eq.false&select=value`, { headers });
    const data = await res.json();
    if (!data || !data.length || !data[0].value) return def;
    try { return JSON.parse(data[0].value); } catch (e) { return def; }
  }

  async function guardarValor(key, valor) {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/app_storage`, {
      method: "POST",
      headers: { ...headers, Prefer: "resolution=merge-duplicates" },
      body: JSON.stringify({ key, value: JSON.stringify(valor), shared: false }),
    });
    if (!res.ok) throw new Error(await res.text());
  }

  async function init() {
    try {
      const veiculos = await getValor("veiculos", []);
      const activos = veiculos.filter((v) => !v.estado || v.estado === "Activo");
      const select = document.getElementById("placa");
      select.innerHTML = '<option value="">Seleccione...</option>' +
        activos.map((v) => `<option value="${v.placa}">${v.placa}</option>`).join("");
      document.getElementById("loading").style.display = "none";
      document.getElementById("form").style.display = "block";
    } catch (e) {
      document.getElementById("loading").textContent = "No se pudo cargar la lista de vehículos. Recargá la página.";
    }
  }

  document.getElementById("form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("btn");
    const msg = document.getElementById("msg");
    msg.className = "msg";
    btn.disabled = true;
    btn.textContent = "Enviando...";

    const nuevo = {
      id: `${Date.now()}_${Math.random().toString(36).slice(2)}`,
      placa: document.getElementById("placa").value,
      motorista: document.getElementById("motorista").value,
      descripcion: document.getElementById("descripcion").value,
      urgencia: document.getElementById("urgencia").value,
      fecha: new Date().toISOString().slice(0, 10),
      estado: "Pendiente",
    };

    try {
      const actuales = await getValor("chamados", []);
      await guardarValor("chamados", [...actuales, nuevo]);
      msg.className = "msg ok";
      msg.textContent = "¡Listo! Tu solicitud fue enviada.";
      document.getElementById("form").reset();
    } catch (err) {
      msg.className = "msg error";
      msg.textContent = "No se pudo enviar. Verificá tu conexión e intentá de nuevo.";
    }
    btn.disabled = false;
    btn.textContent = "Enviar solicitud";
  });

  init();
</script>
</body>
</html>
